{
  "name": "payex-billing-system",
  "version": "1.0.0",
  "description": "**Payex Billing System** — учебный billing-сервис, разрабатываемый как pet-проект для углубления знаний в backend-разработке, проектировании распределённых систем, интеграции микросервисов и построении транспортно-независимой архитектуры.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "setup": "npm install",
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepare": "husky",
    "source-code:generate": "node scripts/generate-project-source.mjs",
    "dev:docker:up": "./scripts/docker-up.sh dev",
    "dev:docker:renew": "./scripts/docker-renew.sh dev",
    "dev:docker:reset": "./scripts/docker-reset.sh dev",
    "dev:docker:control": "./scripts/docker-control.sh dev",
    "prod:docker:up": "./scripts/docker-up.sh prod",
    "prod:docker:renew": "./scripts/docker-renew.sh prod",
    "prod:docker:reset": "./scripts/docker-reset.sh prod",
    "prod:docker:control": "./scripts/docker-control.sh prod"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AveryOn/payex-billing-system.git"
  },
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AveryOn/payex-billing-system/issues"
  },
  "homepage": "https://github.com/AveryOn/payex-billing-system#readme",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
